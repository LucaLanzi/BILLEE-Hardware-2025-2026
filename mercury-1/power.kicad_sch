	)
	(text_box "This power subsystem needs to be able to power sequence the following from their respective batteries.\nArm/Science can share the same battery pack -> Must use a relay triggered by the OBC. GPIO/Serial breakout for Arm. Repurpose for Science.\nComms/RF can use a load switch + switching regulator and draw power from the Logic board depending on the power requirements.\nEthernet Switch can use a load switch + switching regulator and draw power from the Logic Board depending on the power requirements.\nJetson can use load switch + switching regulator and draw power from teh Logic Board depending on the power draw."
		(exclude_from_sim no)
		(at 285.496 60.706 0)
		(size 79.756 25.146)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "a1d6344c-1566-4ed9-a259-848c5ca7bfda")
	)
